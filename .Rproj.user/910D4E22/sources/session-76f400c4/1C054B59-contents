# в”Ђв”Ђ Description: Import and clean ClinicalTrials.gov data в”Ђ

library(tidyverse)
library(janitor)
library(lubridate)

# в”Ђв”Ђ 1. Import raw data в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

trials_raw <- read_csv("data/ctg-studies.csv")

# Check dimensions
nrow(trials_raw)
ncol(trials_raw)

# First look
glimpse(trials_raw)

# в”Ђв”Ђ 2. Clean column names в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

trials_raw <- trials_raw |>
  clean_names()

# Verify
glimpse(trials_raw)

# в”Ђв”Ђ 3. Select relevant columns в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

trials_clean <- trials_raw |>
  select(
    nct_number,
    study_title,
    brief_summary,
    study_status,
    start_date,
    funder_type,
    sponsor,
    conditions
  )

# Verify selection
glimpse(trials_clean)

# в”Ђв”Ђ 4. Fix date column в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

trials_clean <- trials_clean |>
  mutate(
    start_date = parse_date_time(
      start_date,
      orders = c("ymd", "ym"),
      quiet = TRUE
    ) |> as.Date()
  )

# Check date parsing results
sum(!is.na(trials_clean$start_date))  # successfully parsed
sum(is.na(trials_clean$start_date))   # still missing

# в”Ђв”Ђ 5. Save clean data в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

write_csv(trials_clean, "data/trials_clean.csv")
file.exists("data/trials_clean.csv")
